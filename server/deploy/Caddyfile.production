api.zephyrapp.nz {
	reverse_proxy api:{$API_PORT}
}

mcp.zephyrapp.nz {
	reverse_proxy mcp:{$MCP_PORT}
}

zephyrapp.nz www.zephyrapp.nz {
	root * /srv
	encode gzip
	try_files {path} /index.html
	file_server
}

fs.zephyrapp.nz {
	root * /var/www
	file_server
}

logs.zephyrapp.nz {
	reverse_proxy seq:{$SEQ_PORT}
}
